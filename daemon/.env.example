# AgentPort development gateway
# The public gateway wraps the modular file/exec/job gateway and the remaining
# loopback legacy management service.

# Stable identity shared by LAN and virtual-LAN endpoints.
AGENTPORT_SERVER_ID=debian-main
AGENTPORT_WORKSPACE_ID=projects

# Public gateway endpoint used by MCP clients.
AGENTPORT_PUBLIC_PORT=3183
# AGENTPORT_PUBLIC_HOST=0.0.0.0

# Optional fixed loopback port for the legacy compatibility daemon.
# Omit this value to select a free port automatically.
# AGENTPORT_LEGACY_PORT=3184

# Optional external legacy daemon instead of spawning ../server/server.js.
# AGENTPORT_LEGACY_ORIGIN=http://127.0.0.1:3184

# Optional explicit existing daemon environment file.
# AGENTPORT_ENV_PATH=/home/YOUR_USER/.agentport/daemon/.env

# Synchronous command and script execution.
# ALLOW_BASH_EXEC=true
# ALLOWED_COMMANDS=
# ALLOWED_INTERPRETERS=
# EXEC_TIMEOUT_MS=120000
# MAX_EXEC_TIMEOUT_MS=86400000
# EXEC_MAX_CONCURRENCY=2
# EXEC_QUEUE_TIMEOUT_MS=15000
# EXEC_MAX_BUFFER_BYTES=10485760

# Persistent detached jobs.
# Existing JOBS_DIR from the legacy daemon is reused automatically.
# AGENTPORT_JOBS_DIR=/home/YOUR_USER/.agentport/daemon/jobs
# JOB_MAX_CONCURRENCY=2
# JOB_QUEUE_TIMEOUT_MS=15000
# JOB_DEFAULT_TIMEOUT_MS=1800000
# MAX_JOB_TIMEOUT_MS=604800000
# JOB_LOG_CHUNK_BYTES=65536
# JOB_WORKER_READY_TIMEOUT_MS=5000

# Multi-Agent development sessions and Git Worktrees.
# AGENTPORT_SESSIONS_DIR=/home/YOUR_USER/.agentport/sessions
# AGENTPORT_WORKTREES_DIR=/home/YOUR_USER/.agentport/worktrees
# AGENTPORT_SESSION_LEASE_MS=1800000
# AGENTPORT_PROJECT_LOCK_TIMEOUT_MS=15000
# AGENTPORT_PROJECT_LOCK_LEASE_MS=300000
# AGENTPORT_MAX_DIFF_BYTES=2097152
