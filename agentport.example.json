{
  "name": "agentport",
  "version": "2.5.0",
  "description": "AgentPort remote development gateway for MCP, CLI, SSH recovery, and persistent daemon jobs",
  "author": "YOUR_NAME",
  "variables": {
    "remoteUrl": "http://YOUR_SERVER_IP:3183",
    "authToken": "YOUR_CLIENT_TOKEN",
    "clientId": "YOUR_CLIENT_NAME",
    "timeoutMs": "120000",
    "sharedConnectionsPath": "~/.agentport/connections.shared.json",
    "skillDir": "ABSOLUTE_PATH_TO_SKILL_DIR",
    "nodePath": "node",
    "mcpConfigPath": "PATH_TO_YOUR_AI_TOOL_MCP_CONFIG",
    "mcpServerName": "agentport",
    "serverPort": "3183",
    "serverBindHost": "0.0.0.0",
    "serverWorkspaceRoot": "/home/YOUR_USER/YOUR_WORKSPACE",
    "serverEnableDashboard": "true",
    "serverExecTimeoutMs": "120000",
    "serverExecMaxConcurrency": "4",
    "serverExecQueueTimeoutMs": "15000",
    "serverDaemonDir": "/home/YOUR_USER/.agentport/daemon",
    "serverAuditLogPath": "/home/YOUR_USER/.agentport/daemon/audit.log",
    "serverAuthTokens": "client1=token1,client2=token2",
    "serverAdminTokens": "token1,token2"
  },
  "mcp": {
    "server": {
      "command": "${nodePath}",
      "args": [
        "${skillDir}/index.js"
      ],
      "env": {
        "MCP_REMOTE_URL": "${remoteUrl}",
        "MCP_REMOTE_AUTH_TOKEN": "${authToken}",
        "MCP_REMOTE_CLIENT_ID": "${clientId}",
        "MCP_REMOTE_TIMEOUT_MS": "${timeoutMs}",
        "MCP_REMOTE_SHARED_CONNECTIONS_PATH": "${sharedConnectionsPath}"
      }
    }
  }
}