# agentport Server Configuration
# This file is auto-generated by sync.cjs from agentport.json
# Do not edit manually - use agentport.json instead

# Server binding
PORT=3183
BIND_HOST=0.0.0.0

# Workspace root (files will be served from this directory)
WORKSPACE_ROOT=/home/YOUR_USER/YOUR_WORKSPACE

# Dashboard (set to "true" to enable web UI)
ENABLE_DASHBOARD=true

# Execution limits
EXEC_TIMEOUT_MS=120000
EXEC_MAX_CONCURRENCY=4
EXEC_QUEUE_TIMEOUT_MS=15000

# Audit log path
AUDIT_LOG_PATH=/home/YOUR_USER/.agentport/daemon/audit.log
AUDIT_MAX_BYTES=10485760
AUDIT_MAX_FILES=5

# Authentication tokens (format: client1=token1,client2=token2)
AUTH_TOKENS=YOUR_CLIENT_ID=YOUR_TOKEN_HERE

# Admin tokens (comma-separated, for dashboard access)
ADMIN_TOKENS=YOUR_ADMIN_TOKEN_HERE

# Command execution controls (v2.3.1)
# ALLOW_BASH_EXEC=true
# ALLOWED_COMMANDS=ls,cat,grep,find,git,node,npm

# --- Legacy (deprecated) ---
# AUTH_TOKEN is a single-client fallback from older versions. It only takes
# effect when AUTH_TOKENS is empty. Prefer AUTH_TOKENS=clientId=token above.
# AUTH_TOKEN=
