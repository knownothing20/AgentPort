{
  "name": "agentport",
  "version": "2.5.0",
  "description": "AgentPort dual-end remote development gateway for MCP, CLI, SSH recovery, and persistent daemon jobs",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "start": "node client/mcp-entry.js",
    "start:legacy": "node index.js",
    "start:client": "node client/mcp-entry.js",
    "client:cli": "node client/cli-entry.js",
    "start:daemon": "node daemon/server-entry.cjs",
    "cli": "node cli.js",
    "doctor": "node cli.js doctor",
    "setup": "node setup.js",
    "test": "node test.cjs",
    "test:architecture": "node test-architecture.cjs",
    "test:all": "npm run test:architecture && npm run test:lifecycle",
    "test:lifecycle": "node test-cli-lifecycle.cjs",
    "test:mcp": "node test-mcp-windowless.cjs",
    "test:mcp:remote": "node test-mcp-windowless.cjs --remote",
    "sync": "node sync.cjs",
    "sync:check": "node sync.cjs --check",
    "sync:dry": "node sync.cjs --dry-run",
    "sync:skills": "node sync.cjs --skills"
  },
  "bin": {
    "agentport": "./cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.6.8",
    "ssh2": "1.15.0"
  }
}
